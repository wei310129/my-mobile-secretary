<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Local desktop runs write to a bounded rolling file instead of an unbounded redirected console. -->
    <springProfile name="local">
        <property name="LOG_FILE" value="scripts/.logs/spring-boot.log"/>
        <property name="LOGBACK_ROLLINGPOLICY_FILE_NAME_PATTERN"
                  value="${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz"/>
        <property name="LOGBACK_ROLLINGPOLICY_MAX_FILE_SIZE" value="10MB"/>
        <property name="LOGBACK_ROLLINGPOLICY_MAX_HISTORY" value="7"/>
        <property name="LOGBACK_ROLLINGPOLICY_TOTAL_SIZE_CAP" value="100MB"/>
        <include resource="org/springframework/boot/logging/logback/file-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Test and production keep console logging for test reports and container log collectors. -->
    <springProfile name="!local">
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
